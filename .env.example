# ============================================================
#  Peel — Hedera testnet credentials
#  Copy this file to `.env` in every worktree you use.
#  Both `market` and `programme` branches read the same keys.
# ============================================================

# --- Operator (platform-level, used by both workstreams) ---
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxxx
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...

# --- Kitchen accounts (one per demo kitchen) ---
# Create these via Hedera portal or shared/hedera/bootstrap-accounts.ts
KITCHEN_A_ID=0.0.xxxxxx
KITCHEN_A_KEY=302e020100300506032b657004220420...

KITCHEN_B_ID=0.0.xxxxxx
KITCHEN_B_KEY=302e020100300506032b657004220420...

KITCHEN_C_ID=0.0.xxxxxx
KITCHEN_C_KEY=302e020100300506032b657004220420...

# --- LLM (Market workstream only) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Mirror node ---
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
